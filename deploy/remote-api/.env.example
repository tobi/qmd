# Copy to .env and set your API key:
#   cp .env.example .env

# Required: Bearer token for client auth (openssl rand -hex 32)
QMD_GATEWAY_API_KEY=replace-with-strong-token

# Optional: HuggingFace token (speeds up downloads, required for gated models)
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: external port (default 8080)
# QMD_GATEWAY_PORT=8080

# Optional: override model repos/files
# QMD_EMBED_HF_REPO=ggml-org/embeddinggemma-300M-GGUF
# QMD_EMBED_HF_FILE=embeddinggemma-300M-Q8_0.gguf
# QMD_GENERATE_HF_REPO=tobil/qmd-query-expansion-1.7B-gguf
# QMD_GENERATE_HF_FILE=qmd-query-expansion-1.7B-q4_k_m.gguf
# QMD_RERANK_HF_REPO=ggml-org/Qwen3-Reranker-0.6B-Q8_0-GGUF
# QMD_RERANK_HF_FILE=qwen3-reranker-0.6b-q8_0.gguf

# Optional: runtime tuning
# QMD_RERANK_CTX_SIZE=2048
# QMD_EMBED_BATCH_SIZE=512
# QMD_GENERATE_BATCH_SIZE=512
# QMD_RERANK_BATCH_SIZE=256
